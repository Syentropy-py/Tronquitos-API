{
  "name": "Los Tronquitos - Restaurant Reservation WhatsApp Notifications",
  "nodes": [
    {
      "parameters": {
        "path": "tronquitos",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook_trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "cases": [
          {
            "condition": "=",
            "value1": "{{$json.type}}",
            "value2": "reservation",
            "output": 0
          },
          {
            "condition": "=",
            "value1": "{{$json.type}}",
            "value2": "cancellation",
            "output": 1
          },
          {
            "condition": "=",
            "value1": "{{$json.type}}",
            "value2": "table_freed",
            "output": 2
          }
        ],
        "fallbackOutput": 3
      },
      "id": "switch_by_type",
      "name": "Switch - Event Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [450, 300],
      "inputs": ["webhook_trigger"]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "message_field",
              "name": "message",
              "type": "string",
              "value": "🍽️ NUEVA RESERVA\n\nNombre: {{$json.data.Nombre}}\nTeléfono: {{$json.data.Teléfono}}\nEmail: {{$json.data.Email}}\nFecha: {{$json.data.Fecha}}\nHora: {{$json.data.Hora}}\nPersonas: {{$json.data.Personas}}\n\nMesa asignada: {{$json.data.table_number}}\n\n¡Gracias por tu reserva!"
            },
            {
              "id": "to_field",
              "name": "to",
              "type": "string",
              "value": "{{$json.whatsapp_number}}"
            }
          ]
        }
      },
      "id": "set_reservation_message",
      "name": "Set Message - Reservation",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [650, 200],
      "inputs": ["switch_by_type"]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "message_field",
              "name": "message",
              "type": "string",
              "value": "❌ RESERVA CANCELADA\n\nNombre: {{$json.data.Nombre}}\nFecha: {{$json.data.Fecha}}\nHora: {{$json.data.Hora}}\n\nTu reserva ha sido cancelada."
            },
            {
              "id": "to_field",
              "name": "to",
              "type": "string",
              "value": "{{$json.whatsapp_number}}"
            }
          ]
        }
      },
      "id": "set_cancellation_message",
      "name": "Set Message - Cancellation",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [650, 350],
      "inputs": ["switch_by_type"]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "message_field",
              "name": "message",
              "type": "string",
              "value": "🪑 MESA DISPONIBLE\n\nUna mesa ha sido liberada y vuelve a estar disponible."
            },
            {
              "id": "to_field",
              "name": "to",
              "type": "string",
              "value": "{{$json.whatsapp_number}}"
            }
          ]
        }
      },
      "id": "set_table_freed_message",
      "name": "Set Message - Table Freed",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [650, 500],
      "inputs": ["switch_by_type"]
    },
    {
      "parameters": {
        "authentication": "headerSimple",
        "method": "POST",
        "url": "https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_WHATSAPP_ACCESS_TOKEN"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "contentType": "application/json",
        "body": "{\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$json.to}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"{{$json.message}}\"\n  }\n}",
        "options": {
          "retryOn": {
            "enabled": true,
            "maxRetries": 3,
            "waitBetweenRetries": 2000
          }
        }
      },
      "id": "http_whatsapp_reservation",
      "name": "Send WhatsApp - Reservation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [850, 200],
      "inputs": ["set_reservation_message"],
      "onError": "continueRegardless"
    },
    {
      "parameters": {
        "authentication": "headerSimple",
        "method": "POST",
        "url": "https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_WHATSAPP_ACCESS_TOKEN"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "contentType": "application/json",
        "body": "{\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$json.to}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"{{$json.message}}\"\n  }\n}",
        "options": {
          "retryOn": {
            "enabled": true,
            "maxRetries": 3,
            "waitBetweenRetries": 2000
          }
        }
      },
      "id": "http_whatsapp_cancellation",
      "name": "Send WhatsApp - Cancellation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [850, 350],
      "inputs": ["set_cancellation_message"],
      "onError": "continueRegardless"
    },
    {
      "parameters": {
        "authentication": "headerSimple",
        "method": "POST",
        "url": "https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_WHATSAPP_ACCESS_TOKEN"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "contentType": "application/json",
        "body": "{\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$json.to}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"{{$json.message}}\"\n  }\n}",
        "options": {
          "retryOn": {
            "enabled": true,
            "maxRetries": 3,
            "waitBetweenRetries": 2000
          }
        }
      },
      "id": "http_whatsapp_table_freed",
      "name": "Send WhatsApp - Table Freed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [850, 500],
      "inputs": ["set_table_freed_message"],
      "onError": "continueRegardless"
    },
    {
      "parameters": {
        "responseMode": "onReceived"
      },
      "id": "respond_webhook",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1050, 350],
      "inputs": ["http_whatsapp_reservation", "http_whatsapp_cancellation", "http_whatsapp_table_freed"],
      "isActive": true
    }
  ],
  "connections": {
    "webhook_trigger": {
      "main": [
        [
          {
            "node": "switch_by_type",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "switch_by_type": {
      "main": [
        [
          {
            "node": "set_reservation_message",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "set_cancellation_message",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "set_table_freed_message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "set_reservation_message": {
      "main": [
        [
          {
            "node": "http_whatsapp_reservation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "set_cancellation_message": {
      "main": [
        [
          {
            "node": "http_whatsapp_cancellation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "set_table_freed_message": {
      "main": [
        [
          {
            "node": "http_whatsapp_table_freed",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http_whatsapp_reservation": {
      "main": [
        [
          {
            "node": "respond_webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http_whatsapp_cancellation": {
      "main": [
        [
          {
            "node": "respond_webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http_whatsapp_table_freed": {
      "main": [
        [
          {
            "node": "respond_webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  }
}
